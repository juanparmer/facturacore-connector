<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.l10n_co_facturacore</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90" />
        <field name="inherit_id" ref="account.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='audit_trail_setting_container']" position="after">
                <block title="FacturaCore API" name="l10n_co_facturacore_connector">
                    <setting string="Credenciales de API"
                        help="Configure los parámetros de conexión para la API de FacturaCore.">
                        <div class="content-group">
                            <div class="mt16">
                                <label for="facturacore_api_url" string="URL de la API" />
                                <field name="facturacore_api_url"
                                    placeholder="https://api.facturacore.com" />
                            </div>
                            <div class="mt16">
                                <label for="facturacore_api_key" string="API Key" />
                                <field name="facturacore_api_key" password="True" />
                                <field name="l10n_co_dian_environment" />
                            </div>
                        </div>
                    </setting>
                    <setting string="Certificado Digital y Software"
                        help="Detalles del certificado PFX y registro de Software DIAN.">
                        <div class="content-group">
                            <div class="mt16">
                                <label for="l10n_co_pfx_filename" string="Nombre del archivo PFX" />
                                <field name="l10n_co_pfx_filename" placeholder="empresa.pfx" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_pfx_password" string="Contraseña PFX" />
                                <field name="l10n_co_pfx_password" password="True" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_software_id" string="Software ID" />
                                <field name="l10n_co_software_id" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_software_pin" string="Software PIN" />
                                <field name="l10n_co_software_pin" password="True" placeholder="12345" />
                            </div>
                        </div>
                    </setting>
                    <setting string="Resolución de Facturación DIAN"
                        help="Datos de la resolución actual autorizada por la DIAN.">
                        <div class="content-group">
                            <div class="mt16">
                                <label for="l10n_co_resolution_number" string="Número Resolución" />
                                <field name="l10n_co_resolution_number" placeholder="18760000001" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_resolution_prefix" string="Prefijo" />
                                <field name="l10n_co_resolution_prefix" placeholder="SETT" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_resolution_date_from" string="Fecha Desde" />
                                <field name="l10n_co_resolution_date_from" />
                                <label for="l10n_co_resolution_date_to" string="Fecha Hasta" class="ml-2"/>
                                <field name="l10n_co_resolution_date_to" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_resolution_range_from" string="Rango Desde" />
                                <field name="l10n_co_resolution_range_from" />
                                <label for="l10n_co_resolution_range_to" string="Rango Hasta" class="ml-2" />
                                <field name="l10n_co_resolution_range_to" />
                            </div>
                            <div class="mt16">
                                <label for="l10n_co_technical_key" string="Clave Técnica" />
                                <field name="l10n_co_technical_key" password="True" />
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>